# Copy to .env and fill in real values. Never commit .env.

# Supabase Postgres (Project Settings → Database → Connect)
# On Render you MUST use the Connection pooler (IPv4). Direct db.*:5432 is often IPv6-only and fails with "Network is unreachable".
# Session mode pooler example (port 6543). Username is often postgres.YOUR_PROJECT_REF
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

APP_BASE_URL=http://localhost:8000
DSA_SESSION_SECRET=change-me-in-production

# Optional email (locked in UI on Render free; still used if you enable later)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=DSA Revision Helper <you@gmail.com>
SMTP_TLS=1
