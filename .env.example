# Copy to .env and fill in real values. Never commit .env.

# Supabase Postgres (Project Settings → Database → URI)
# Prefer the pooler URI (:6543) on Render to avoid connection limits.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

APP_BASE_URL=http://localhost:8000
DSA_SESSION_SECRET=change-me-in-production

# Optional email (locked in UI on Render free; still used if you enable later)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=DSA Revision Helper <you@gmail.com>
SMTP_TLS=1
